#!/usr/bin/env bash
# hl gpu  -- pretty-printed GPU snapshot. With --watch, refresh every 2s.

set -euo pipefail
HL_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$HL_BIN_DIR/lib.sh"

watch=0
for a in "$@"; do
	case "$a" in
		-w|--watch) watch=1 ;;
		-h|--help) cat <<EOF; exit 0
hl gpu [--watch]
  Show GPU name, VRAM, utilization, temp, and what is using VRAM.
  --watch     refresh every 2 seconds (Ctrl-C to stop)
EOF
		;;
	esac
done

hl_have_gpu || hl_die "nvidia-smi not found -- is the NVIDIA driver / WSL CUDA shim available?"
NVIDIA_SMI="$(hl_nvidia_smi)"

render() {
	hl_h1 "GPU"
	"$NVIDIA_SMI" \
		--query-gpu=index,name,driver_version,memory.total,memory.used,memory.free,utilization.gpu,temperature.gpu,power.draw,power.limit \
		--format=csv 2>/dev/null \
	  | column -t -s, \
	  | sed 's/^/  /'

	echo
	hl_h1 "VRAM users"
	local procs
	procs=$("$NVIDIA_SMI" --query-compute-apps=pid,process_name,used_memory --format=csv,noheader 2>/dev/null || true)
	if [ -z "$procs" ]; then
		printf "  %sno compute processes on the GPU%s\n" "$C_DIM" "$C_RESET"
	else
		printf "  %-8s  %-50s  %s\n" "PID" "PROCESS" "VRAM"
		echo "$procs" | awk -F', ' '{printf "  %-8s  %-50s  %s\n", $1, $2, $3}'
	fi

	# Ollama-specific snapshot if the container is up
	if hl_docker_ready && docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^ollama$'; then
		echo
		hl_h1 "Ollama loaded models"
		docker exec ollama ollama ps 2>/dev/null | sed 's/^/  /' || \
			printf "  %sollama ps failed%s\n" "$C_DIM" "$C_RESET"
	fi
}

if [ "$watch" -eq 1 ]; then
	while true; do clear; render; sleep 2; done
else
	render
fi
