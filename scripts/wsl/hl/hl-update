#!/usr/bin/env bash
# hl update -- update Ubuntu packages and compose stack images.

set -euo pipefail
HL_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$HL_BIN_DIR/lib.sh"

run_apt=1
run_compose=1
run_prune=0

usage() {
	cat <<EOF
hl update [--no-apt] [--no-compose] [--prune]
  Update Ubuntu packages and pull/recreate compose stacks.
  --no-apt       skip apt update/upgrade/autoremove
  --no-compose   skip docker compose pull/up
  --prune        run docker system prune after compose updates
EOF
}

while [ $# -gt 0 ]; do
	case "$1" in
		--no-apt)     run_apt=0; shift ;;
		--no-compose) run_compose=0; shift ;;
		--prune)      run_prune=1; shift ;;
		-h|--help)    usage; exit 0 ;;
		*)            hl_usage_die "unknown option: $1" ;;
	esac
done

if [ "$run_apt" -eq 1 ]; then
	hl_h1 "Ubuntu packages"
	sudo apt-get update
	sudo DEBIAN_FRONTEND=noninteractive apt-get upgrade -y
	sudo DEBIAN_FRONTEND=noninteractive apt-get autoremove --purge -y
	hl_ok "Ubuntu packages updated"
fi

if [ "$run_compose" -eq 1 ]; then
	hl_h1 "Compose stacks"
	if ! hl_docker_ready; then
		hl_warn "docker not available; skipping compose image updates"
	else
		count=0
		while read -r stack; do
			[ -n "$stack" ] || continue
			cf=$(hl_stack_path "$stack") || continue
			count=$((count+1))
			hl_info "updating stack '$stack'"
			running=$(( $(docker compose -f "$cf" ps --status running -q 2>/dev/null | wc -l) + 0 ))
			docker compose -f "$cf" pull
			if [ "$running" -gt 0 ]; then
				docker compose -f "$cf" up -d --remove-orphans
			else
				printf "  %sleaving stopped stack stopped: %s%s\n" "$C_DIM" "$stack" "$C_RESET"
			fi
		done < <(hl_stacks)
		if [ "$count" -eq 0 ]; then
			printf "  %sno compose stacks under %s/docker%s\n" "$C_DIM" "$HL_REPO" "$C_RESET"
		else
			hl_ok "compose stacks updated"
		fi
	fi
fi

if [ "$run_prune" -eq 1 ]; then
	hl_h1 "Docker prune"
	if hl_docker_ready; then
		docker system prune -f
		hl_ok "docker system prune complete"
	else
		hl_warn "docker not available; skipping prune"
	fi
fi

hl_ok "update complete"
