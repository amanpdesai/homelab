#!/usr/bin/env bash
# hl up [stack]  -- docker compose up -d for a stack.
# Without an arg, prompt to pick from discovered stacks.

set -euo pipefail
HL_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$HL_BIN_DIR/lib.sh"

case "${1:-}" in
	-h|--help)
		cat <<EOF
hl up [stack]
  Start a compose stack with docker compose up -d.
  Without a stack name, pick from discovered stacks.
EOF
		exit 0
		;;
esac

hl_docker_ready || hl_die "docker is not available"

stack=$(hl_resolve_stack "${1:-}") || hl_die "no stack selected"
cf=$(hl_stack_path "$stack")       || hl_die "stack not found: $stack"

hl_info "starting stack '$stack'  ($cf)"
docker compose -f "$cf" up -d
hl_ok "stack '$stack' is up"

# Show the result
docker compose -f "$cf" ps --format 'table {{.Name}}\t{{.State}}\t{{.Status}}\t{{.Ports}}' | sed 's/^/  /'
